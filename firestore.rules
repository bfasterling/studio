/**
 * @fileOverview Firestore Security Rules for DocuChat AI (Shared Model).
 *
 * Core Philosophy:
 * This ruleset treats the application as a shared, public knowledge base.
 * Any authenticated user (including anonymous users) can read and write documents and conversations.
 * This facilitates a collaborative environment where all uploaded content and chat history is accessible to everyone.
 *
 * Data Structure:
 * - /documents/{documentId}: A global collection for all uploaded documents.
 * - /analysis_instructions/{analysisInstructionId}: Admin-created instructions (publicly readable).
 * - /documents/{documentId}/analyses/{analysisId}: Analysis results for a given document.
 * - /conversations/{conversationId}: A global collection for all Q&A conversation turns.
 *
 * Key Security Decisions:
 * - Any authenticated user can create, read, update, or delete any document.
 * - Any authenticated user can read, create, update, or delete conversation turns.
 * - This open model is intentional for a shared-knowledge-base application.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user-uploaded documents under the /documents/{documentId} path.
     * Allows any authenticated user to perform read and write operations.
     * @path /documents/{documentId}
     * @allow (read, write) Any authenticated user can create, read, update, or delete documents.
     * @principle Enables a shared, collaborative document repository.
     */
    match /documents/{documentId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Allows public read access to analysis instructions.
     * @path /analysis_instructions/{analysisInstructionId}
     * @allow (get, list) Any user can read instructions.
     * @deny (write) No client can write to instructions.
     * @principle Makes analysis instructions globally available while restricting modification.
     */
    match /analysis_instructions/{analysisInstructionId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Protects document analysis results.
     * @path /documents/{documentId}/analyses/{analysisId}
     * @allow (read, write) Any authenticated user can manage analyses for any document.
     * @principle Allows collaborative analysis on the shared documents.
     */
    match /documents/{documentId}/analyses/{analysisId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Protects conversation turns, ensuring users can only access their own.
     * @path /conversations/{conversationId}
     * @allow (create) A user can create a conversation for themselves.
     * @allow (read) A user can read their own conversations. This also secures list queries.
     * @deny (update, delete) Updating or deleting conversations is disallowed.
     * @principle Enforces private, user-specific chat histories.
     */
    match /conversations/{conversationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
